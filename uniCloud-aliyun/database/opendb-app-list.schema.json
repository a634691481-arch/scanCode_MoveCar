{
  "bsonType": "object",
  "required": ["type", "appid", "name"],
  "properties": {
    "_id": {
      "title": "ID"
    },
    "_add_time": {
      "title": "添加时间",
      "bsonType": "timestamp",
      "forceDefaultValue": { "$env": "now" }
    },
    "type": {
      "title": "应用类型",
      "bsonType": "string",
      "description": "如 admin、client、rider、business （可自定义）"
    },
    "appid": {
      "title": "AppID",
      "bsonType": "string",
      "description": "应用的AppID"
    },
    "app_type": {
      "title": "应用类型",
      "bsonType": "int",
      "defaultValue": 0,
      "enum": [
        { "value": 0, "text": "uni-app" },
        { "value": 1, "text": "uni-app x" }
      ]
    },
    "name": {
      "title": "应用名称",
      "bsonType": "string",
      "description": "如 管理端、用户端、骑手端、商家端"
    },
    "description": {
      "title": "应用描述",
      "bsonType": "string"
    },
    "create_date": {
      "title": "创建时间",
      "bsonType": "timestamp",
      "description": "创建时间"
    },
    "creator_uid": {
      "title": "创建者ID",
      "bsonType": "string",
      "foreignKey": "uni-id-users._id"
    },
    "enable_upgrade_center": {
      "title": "是否启用App升级中心",
      "bsonType": "bool"
    },
    "introduction": {
      "title": "应用简介",
      "bsonType": "string"
    },
    "icon_url": {
      "title": "应用图标链接",
      "bsonType": "string"
    },
    "screenshot": {
      "title": "应用截图",
      "bsonType": "array",
      "arrayType": "string"
    },
    "app_android": {
